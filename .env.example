# ============================================================
# CNVRTED V2 — Environment Variables
# Copy this to .env and fill in your keys
# ============================================================

# ── Supabase (V2 project) ───────────────────────────────────
# Get from: supabase.com → your project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Anthropic ───────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Reddit (PRAW) ───────────────────────────────────────────
# Get from: reddit.com/prefs/apps → create app (script type)
PRAW_CLIENT_ID=your_reddit_client_id
PRAW_CLIENT_SECRET=your_reddit_client_secret
PRAW_USER_AGENT=cnvrted/2.0

# ── Search APIs ─────────────────────────────────────────────
# Serper: serper.dev → API Key (2,500 free queries)
SERPER_API_KEY=your_serper_key

# Exa: exa.ai → Dashboard → API Key (1,000 free searches/month)
EXA_API_KEY=your_exa_key

# Tavily: app.tavily.com → API Key (fallback for Exa)
TAVILY_API_KEY=your_tavily_key

# ── Enrichment APIs ─────────────────────────────────────────
# Hunter.io: hunter.io → API → API Key (50 free/month)
HUNTER_API_KEY=your_hunter_key

# FullEnrich: fullenrich.com (pay per credit)
FULLENRICH_API_KEY=your_fullenrich_key

# Apollo: apollo.io → Settings → Integrations → API Key
APOLLO_API_KEY=your_apollo_key

# ── Scoring thresholds (optional, defaults are fine) ────────
VECTOR_SIMILARITY_THRESHOLD=0.70
INTENT_SCORE_THRESHOLD=0.60
MAX_LEADS_PER_DAY=20

# ── V1 legacy (keep so V1 routes don't break) ───────────────
APIFY_API_TOKEN=your_apify_token
